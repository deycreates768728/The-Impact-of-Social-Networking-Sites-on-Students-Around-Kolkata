#Pie chart for the sex distribution:
# Read the CSV file
My.file <- read.csv("C:\\Users\\SOURAV\\Desktop\\SEM - 4\\SEM - 4 AKG\\Group Report Survey\\Unlock the insights.csv")

# Check the structure of the data
str(My.file)

# The column name "Sex"
# Creating the pie chart
sex_counts <- table(My.file$Sex)
pie(sex_counts, labels = paste(names(sex_counts), ": ",
	sex_counts), main = "Sex Distribution")




#Column diagram (bar plot) for age distribution:
# Assuming the column name is "Age" 
# Creating the bar plot
barplot(table(My.file$Age),
	main = "Age Distribution",
	xlab = "Age",
	ylab = "Frequency",
	col = "turquoise",
	legend.text = TRUE)


#pie chart for annual family income:
# Assuming the column name for annual family income is "AnnualFamilyIncome"
# Creating the pie chart
income_counts <- table(My.file$Annual.family.income)
pie(income_counts,
	labels = paste(names(income_counts), ": ",
	round(income_counts/sum(income_counts)*100), "%"),
	main = "Annual Family Income Distribution",
	col = rainbow(length(income_counts)))
legend("topright", legend = names(income_counts),
	fill = rainbow(length(income_counts)))



